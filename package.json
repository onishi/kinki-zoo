{
  "name": "kinki-zoo",
  "version": "1.0.0",
  "description": "近畿一円の動物園情報を提供する Cloudflare Workers サービス",
  "main": "src/index.ts",
  "scripts": {
    "dev": "npx wrangler dev --port 8001",
    "deploy": "npx wrangler deploy",
    "d1:migrate": "npx wrangler d1 migrations apply kinki-zoo-animals",
    "d1:migrate:remote": "npx wrangler d1 migrations apply kinki-zoo-animals --remote",
    "sync:jaza": "node scripts/sync-jaza-members.mjs",
    "check:jaza": "node scripts/check-jaza-coverage.mjs",
    "classify:unclassified": "node scripts/classify-unclassified.mjs",
    "generate:animal-images": "node scripts/generate-animal-images.mjs",
    "generate:all-animal-images": "node scripts/generate-all-animal-images.mjs",
    "upload:images-to-r2": "node scripts/upload-images-to-r2.mjs",
    "sync:remote": "node scripts/sync-to-remote.mjs",
    "typecheck": "npx tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "wrangler": "^4.105.0"
  }
}
